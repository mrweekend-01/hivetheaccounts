# ==== Base de datos ====
POSTGRES_USER=hth
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=hth_accounts

# ==== Backend ====
# Para desarrollo local sin docker usa: postgresql://hth:cambia_esto@localhost:5432/hth_accounts
DATABASE_URL=postgresql://hth:cambia_esto@db:5432/hth_accounts

# Clave para firmar JWT. Genera una con: openssl rand -hex 32
SECRET_KEY=pon_aqui_un_hex_de_64_caracteres

# Clave para CIFRAR credenciales (correo/redes/proxy). NO la pierdas: sin ella no se descifran.
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=pon_aqui_una_fernet_key

ACCESS_TOKEN_EXPIRE_MINUTES=480
HUMANIZATION_MINUTES=30
CORS_ORIGINS=http://localhost:5173

# ==== Frontend ====
VITE_API_URL=http://localhost:8000
