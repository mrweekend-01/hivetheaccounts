# ==== Copia este archivo a .env.prod y completa los valores ====

# Combinación usuario-de-github/nombre-del-repo (así se llaman las imágenes
# que publica GitHub Actions: ghcr.io/IMAGE_BASE-backend, ghcr.io/IMAGE_BASE-frontend)
IMAGE_BASE=mrweekend-01/hivetheaccounts

# ==== Base de datos (puedes dejar estos valores o cambiarlos) ====
POSTGRES_USER=hth
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=hth_accounts

# ==== Backend ====
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pon_aqui_un_hex_de_64_caracteres
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=pon_aqui_una_fernet_key

ACCESS_TOKEN_EXPIRE_MINUTES=480
HUMANIZATION_MINUTES=30

# Direcciones desde las que el navegador puede llamar al backend.
# Incluye localhost Y la IP de la PC donde corre esto en su red local.
CORS_ORIGINS=http://localhost,http://192.168.1.100

# ==== Frontend ====
# La IP/dominio con el que los operadores van a acceder al backend desde
# SUS navegadores (normalmente la IP de esta PC en la red local de HTH).
API_URL=http://192.168.1.100:8000
